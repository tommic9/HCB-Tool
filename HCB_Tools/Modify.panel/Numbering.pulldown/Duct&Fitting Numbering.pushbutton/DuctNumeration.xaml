<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="DuctNumeration"
    Height="220" Width="380"
    WindowStartupLocation="CenterScreen"
    HorizontalAlignment="Center"
    ShowInTaskbar="True"
    WindowStyle="None"
    ResizeMode="NoResize"
    Background="#2E466F">

    <Window.Resources>
        <!-- Kolory HellCold -->
        <SolidColorBrush x:Key="header_background"  Color="#2E466F" />
        <SolidColorBrush x:Key="text_white"         Color="#FFFFFF" />
        <SolidColorBrush x:Key="button_fg_normal"   Color="#FFFFFF" />
        <SolidColorBrush x:Key="button_bg_normal"   Color="#2E466F" />
        <SolidColorBrush x:Key="button_bg_hover"    Color="#1F8ECE" />
        <SolidColorBrush x:Key="border_blue"        Color="#1F8ECE" />

        <!-- Globalne style -->
        <Style TargetType="{x:Type Control}">
            <Setter Property="FontFamily" Value="Segoe UI Light"/>
            <Setter Property="Foreground" Value="{StaticResource text_white}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background"     Value="{StaticResource button_bg_normal}"/>
            <Setter Property="Foreground"     Value="{StaticResource button_fg_normal}"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="BorderBrush"    Value="{StaticResource border_blue}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource button_bg_hover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource text_white}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource text_white}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0"
              Background="{StaticResource header_background}"
              MouseDown="header_drag">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>

            <!-- LOGO / link -->
            <DockPanel Grid.Column="0"
                       Grid.ColumnSpan="2"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left">
                <TextBlock Margin="5,0,0,0">
                    <Hyperlink
                        RequestNavigate="Hyperlink_RequestNavigate"
                        NavigateUri="https://www.hellcold.pl/"
                        FontSize="14"
                        FontWeight="Heavy"
                        Foreground="{StaticResource text_white}">
                        HellCold
                    </Hyperlink>
                </TextBlock>
            </DockPanel>

            <!-- Tytuł -->
            <TextBlock x:Name="main_title"
                       Text="DuctNumeration"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource text_white}"/>

            <!-- CLOSE -->
            <Button
                Content="Close"
                Grid.Column="2"
                Width="60" Height="20"
                FontSize="10"
                Click="button_close"
                VerticalAlignment="Center"
                HorizontalAlignment="Right"/>
        </Grid>

        <!-- MAIN -->
        <StackPanel Grid.Row="1" Margin="10">
            <!-- Tekst z kolorem tylko na Run -->
            <TextBlock Margin="0,0,0,10">
                <Run Text="Wdług którego parametru scalić numerację? (Duct):"
                     Foreground="{StaticResource text_white}"/>
            </TextBlock>

            <!-- Dwa checkboxy + trzeci parametr projektu -->
            <CheckBox x:Name="checkbox_length"
                      Content="Length (Parametr domyślny)"
                      IsChecked="True"
                      Margin="5,0,0,5"
                      Checked="checkbox_length_checked"/>

            <CheckBox x:Name="checkbox_hc"
                      Content="HC__Order__Length (Długość zamówieniowa)"
                      IsChecked="False"
                      Margin="5,0,0,5"
                      Checked="checkbox_hc_checked"/>

            <CheckBox x:Name="checkbox_extended"
                      Content="Powiększona długość"
                      IsChecked="False"
                      Margin="5,0,0,10"
                      Checked="checkbox_extended_checked"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="OK"
                        Width="80" Height="24"
                        Margin="0,0,5,0"
                        Click="button_ok"/>
                <Button Content="Anuluj"
                        Width="80" Height="24"
                        Click="button_cancel"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
