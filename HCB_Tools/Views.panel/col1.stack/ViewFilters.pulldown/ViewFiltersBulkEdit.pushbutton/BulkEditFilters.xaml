<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="ViewFilters: Bulk Edit"
    Height="940" Width="525"
    WindowStartupLocation="CenterScreen"
    HorizontalAlignment="Center"
    ShowInTaskbar="True"
    WindowStyle="None"
    ResizeMode="NoResize"
    Background="#2E466F">

    <Window.Resources>
        <ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                            xmlns:local="clr-namespace:Common.WPF_styles">

            <SolidColorBrush x:Key="header_background" Color="#2E466F"/>
            <SolidColorBrush x:Key="text_white" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="text_blue" Color="#1F8ECE"/>
            <SolidColorBrush x:Key="button_fg_normal" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="button_bg_normal" Color="#2E466F"/>
            <SolidColorBrush x:Key="button_bg_hover" Color="#1F8ECE"/>
            <SolidColorBrush x:Key="border_blue" Color="#1F8ECE"/>
            <SolidColorBrush x:Key="border_blue" Color="#1F8ECE"/>
            <SolidColorBrush x:Key="checkbox_checked_colour" Color="#1F8ECE"/>

            <Style TargetType="{x:Type Control}">
                <Setter Property="FontFamily" Value="Segoe UI Light"/>
            </Style>

            <Style TargetType="Button">
                <Setter Property="TextElement.FontFamily" Value="Segoe UI Light"/>
                <Setter Property="Background" Value="{StaticResource button_bg_normal}"/>
                <Setter Property="Foreground" Value="{StaticResource button_fg_normal}"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="BorderBrush" Value="{StaticResource border_blue}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="8"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource button_bg_hover}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe UI Light"/>
                <Setter Property="Foreground" Value="{StaticResource text_white}"/>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource header_background}"/>
                <Setter Property="Foreground" Value="{StaticResource text_blue}"/>
                <Setter Property="BorderBrush" Value="{StaticResource border_blue}"/>
                <Style.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Style.Resources>
            </Style>

            <Style TargetType="Label">
                <Setter Property="Foreground" Value="{StaticResource text_white}"/>
            </Style>

            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="{StaticResource text_white}"/>
                <Setter Property="BorderBrush" Value="{StaticResource border_blue}"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>

            <Style TargetType="Border">
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="7"/>
            </Style>

            <Style TargetType="ListBox">
                <Style.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Style.Resources>
            </Style>

            <Style x:Key="RepeatButtonTransparent" TargetType="{x:Type RepeatButton}">
                <Setter Property="OverridesDefaultStyle" Value="true"/>
                <Setter Property="Background" Value="{StaticResource header_background}"/>
                <Setter Property="Focusable" Value="false"/>
                <Setter Property="IsTabStop" Value="false"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type RepeatButton}">
                            <Border Background="{TemplateBinding Background}"
                                    Height="{TemplateBinding Height}"
                                    Width="{TemplateBinding Width}"
                                    CornerRadius="10"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ScrollBarThumbVertical" TargetType="{x:Type Thumb}">
                <Setter Property="OverridesDefaultStyle" Value="true"/>
                <Setter Property="IsTabStop" Value="false"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Thumb}">
                            <Border x:Name="rectangle"
                                    Background="{StaticResource border_blue}"
                                    Height="{TemplateBinding Height}"
                                    SnapsToDevicePixels="True"
                                    Width="{TemplateBinding Width}"
                                    CornerRadius="8"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="true">
                                    <Setter Property="Background" TargetName="rectangle" Value="{StaticResource button_bg_hover}"/>
                                </Trigger>
                                <Trigger Property="IsDragging" Value="true">
                                    <Setter Property="Background" TargetName="rectangle" Value="{StaticResource button_bg_normal}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="{x:Type ScrollBar}">
                <Setter Property="Background" Value="{StaticResource border_blue}"/>
                <Setter Property="Foreground" Value="{StaticResource border_blue}"/>
                <Setter Property="BorderBrush" Value="{StaticResource header_background}"/>
                <Setter Property="Opacity" Value="0.9"/>
                <Setter Property="Margin" Value="3"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Grid x:Name="Bg"
                                  SnapsToDevicePixels="true">
                                <Border BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="5"/>
                                <Track x:Name="PART_Track"
                                       IsDirectionReversed="true"
                                       IsEnabled="{TemplateBinding IsMouseOver}">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollBarThumbVertical}"
                                               Margin="2"/>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid MouseDown="header_drag"
              Background="{StaticResource header_background}"
              Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="75"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0"
                       Grid.ColumnSpan="2"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left">
                <TextBlock Margin="5,0,0,0">
                    <Hyperlink RequestNavigate="Hyperlink_RequestNavigate"
                               NavigateUri="https://www.hellcold.pl/"
                               FontSize="14px"
                               FontWeight="Heavy"
                               Foreground="{StaticResource text_white}">
                        HellCold
                    </Hyperlink>
                </TextBlock>
            </DockPanel>

            <TextBlock x:Name="main_title"
                       Text="__title__"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource text_white}"/>

            <Button Content="Close"
                    Grid.Column="2"
                    Width="60" Height="20"
                    FontSize="10"
                    Click="button_close"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right"/>
        </Grid>

        <ScrollViewer Grid.Row="1" Margin="10"
                      VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar">
                    <Setter Property="Background" Value="{StaticResource border_magenta}"/>
                    <Setter Property="Foreground" Value="{StaticResource border_magenta}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource header_background}"/>
                    <Setter Property="Opacity" Value="0.9"/>
                    <Setter Property="Margin" Value="3"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ScrollBar}">
                                <Grid x:Name="Bg"
                                      SnapsToDevicePixels="true">
                                    <Border BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="5"/>
                                    <Track x:Name="PART_Track"
                                           IsDirectionReversed="true"
                                           IsEnabled="{TemplateBinding IsMouseOver}">
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumbVertical}"
                                                   Margin="2"/>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ScrollViewer.Resources>
            <StackPanel>
                <Label Content="Wybierz widoki:" Margin="0,0,0,-10"/>
                <DockPanel>
                    <Label Content="🔍"
                           VerticalAlignment="Top" Height="23"
                           Foreground="{StaticResource text_white}"
                           Margin="0,5,-10,5"/>
                    <TextBox x:Name="textbox_filter"
                             Height="22"
                             VerticalAlignment="Top"
                             Margin="10,8,5,5"
                             FontSize="14"
                             BorderBrush="{StaticResource border_blue}"
                             TextChanged="UI_text_filter_updated"/>
                </DockPanel>

                <ListBox x:Name="UI_ListBox_Views"
                         Margin="5,0,5,0"
                         Height="160"
                         Background="{StaticResource header_background}"
                         SelectionMode="Multiple"
                         ScrollViewer.VerticalScrollBarVisibility="Visible"
                         ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                         BorderBrush="{StaticResource border_blue}">
                    <ListBox.Resources>
                        <Style TargetType="ScrollBar">
                            <Setter Property="Background" Value="{StaticResource border_magenta}"/>
                            <Setter Property="Foreground" Value="{StaticResource border_magenta}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource header_background}"/>
                            <Setter Property="Opacity" Value="0.9"/>
                            <Setter Property="Margin" Value="3"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                                        <Grid x:Name="Bg"
                                              SnapsToDevicePixels="true">
                                            <Border BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="5"/>
                                            <Track x:Name="PART_Track"
                                                   IsDirectionReversed="true"
                                                   IsEnabled="{TemplateBinding IsMouseOver}">
                                                <Track.Thumb>
                                                    <Thumb Style="{StaticResource ScrollBarThumbVertical}"
                                                           Margin="2"/>
                                                </Track.Thumb>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </ListBox.Resources>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Background="{StaticResource checkbox_checked_colour}"
                                      Foreground="{StaticResource text_white}"
                                      IsChecked="{Binding IsChecked}"
                                      Checked="UIe_ViewChecked"
                                      Unchecked="UIe_ViewUnchecked">
                                <TextBlock Text="{Binding Name}"/>
                            </CheckBox>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <DockPanel Margin="15,5,0,10">
                    <CheckBox x:Name="UI_checkbox_views"
                              Content="Views"
                              IsChecked="True"
                              Margin="0,2,20,2"
                              Checked="UI_event_checked_views"
                              Unchecked="UI_event_checked_views"/>
                    <CheckBox x:Name="UI_checkbox_view_templates"
                              Content="ViewTemplates"
                              IsChecked="True"
                              Margin="0,2,0,2"
                              Checked="UI_event_checked_views"
                              Unchecked="UI_event_checked_views"/>
                </DockPanel>

                <Separator Margin="5,10,5,10" Background="{StaticResource border_blue}"/>

                <Label Content="Wybierz filtry:"/>
                <ListBox x:Name="UI_ListBox_Filters"
                         Margin="5,0,5,0"
                         Height="160"
                         Background="{StaticResource header_background}"
                         SelectionMode="Multiple"
                         ScrollViewer.VerticalScrollBarVisibility="Visible"
                         ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                         BorderBrush="{StaticResource border_blue}">
                    <ListBox.Resources>
                        <Style TargetType="ScrollBar">
                            <Setter Property="Background" Value="{StaticResource border_magenta}"/>
                            <Setter Property="Foreground" Value="{StaticResource border_magenta}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource header_background}"/>
                            <Setter Property="Opacity" Value="0.9"/>
                            <Setter Property="Margin" Value="3"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                                        <Grid x:Name="Bg"
                                              SnapsToDevicePixels="true">
                                            <Border BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="5"/>
                                            <Track x:Name="PART_Track"
                                                   IsDirectionReversed="true"
                                                   IsEnabled="{TemplateBinding IsMouseOver}">
                                                <Track.Thumb>
                                                    <Thumb Style="{StaticResource ScrollBarThumbVertical}"
                                                           Margin="2"/>
                                                </Track.Thumb>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </ListBox.Resources>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Background="{StaticResource checkbox_checked_colour}"
                                      Foreground="{StaticResource text_white}"
                                      IsChecked="{Binding IsChecked}"
                                      Checked="UIe_FilterChecked"
                                      Unchecked="UIe_FilterUnchecked">
                                <TextBlock Text="{Binding Name}"/>
                            </CheckBox>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,5,0,10">
                    <Button Content="Zaznacz wszystkie"
                            Click="button_select_all"
                            Height="20"
                            Width="140"
                            Margin="5"/>
                    <Button Content="Wyczyść"
                            Click="button_select_none"
                            Height="20"
                            Width="100"
                            Margin="5"/>
                </StackPanel>

                <Separator Margin="5,5,5,10" Background="{StaticResource border_blue}"/>

                <Label Content="Akcje:"/>
                <StackPanel Margin="5,0,5,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Label Content="Status filtra:" Width="110" VerticalAlignment="Center"/>
                        <ComboBox x:Name="UI_Enable_Action"
                                  Width="200"
                                  SelectionChanged="UI_Enable_Changed">
                            <ComboBoxItem Content="Bez zmian" Tag="no_change" IsSelected="True"/>
                            <ComboBoxItem Content="Aktywuj" Tag="enable"/>
                            <ComboBoxItem Content="Dezaktywuj" Tag="disable"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Widoczność:" Width="110" VerticalAlignment="Center"/>
                        <ComboBox x:Name="UI_Visibility_Action"
                                  Width="200"
                                  SelectionChanged="UI_Visibility_Changed">
                            <ComboBoxItem Content="Bez zmian" Tag="no_change" IsSelected="True"/>
                            <ComboBoxItem Content="Widoczny" Tag="visible"/>
                            <ComboBoxItem Content="Ukryty" Tag="hidden"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>

                <Button Click="button_run"
                        Content="Zastosuj"
                        Margin="0,20,0,0"
                        Width="210"
                        Height="30"
                        HorizontalAlignment="Center"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
