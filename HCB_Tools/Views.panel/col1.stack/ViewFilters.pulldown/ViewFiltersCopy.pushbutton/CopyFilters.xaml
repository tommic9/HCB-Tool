                                               IsEnabled="{TemplateBinding IsMouseOver}"
                                               Grid.Row="1">
                                            <Track.Thumb>
                                                <Thumb Style="{StaticResource ScrollBarThumbVertical}"
                                                       Margin="2"/>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>

                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.Resources>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Background="{StaticResource checkbox_checked_colour}"
                                  Foreground="{StaticResource text_white}"
                                  IsChecked="{Binding IsChecked}"
                                  Checked="UIe_FilterChecked"
                                  Unchecked="UIe_FilterUnchecked">
                            <TextBlock Text="{Binding Name}"/>
                        </CheckBox>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

                        <!-- DESTINATION VIEWS -->
            <Separator Margin="5,10,5,5" Background="{StaticResource border_magenta}"/>

            <Label Content="Destination Views:"
                   Margin="0,0,0,2"/>

            <ListBox x:Name="UI_ListBox_Dest_Views"
                     Margin="5,0,5,0"
                     Height="150"
                     Background="{StaticResource header_background}"
                     SelectionMode="Multiple"
                     ScrollViewer.VerticalScrollBarVisibility="Visible"
                     ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                     BorderBrush="{StaticResource border_magenta}">

                <ListBox.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Background" Value="{StaticResource border_magenta}"/>
                        <Setter Property="Foreground" Value="{StaticResource border_magenta}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource header_background}"/>
                        <Setter Property="Opacity" Value="0.9"/>
                        <Setter Property="Margin" Value="3"/>

                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ScrollBar}">
                                    <Grid x:Name="Bg"
                                          SnapsToDevicePixels="true">
                                        <Border BorderBrush     = "{TemplateBinding BorderBrush}"
                                                BorderThickness = "{TemplateBinding BorderThickness}"
                                                Background      = "{TemplateBinding Background}"
                                                Grid.Row        = "1"
                                                CornerRadius="10"/>

                                        <Track x:Name="PART_Track"
                                               IsDirectionReversed="true"
                                               IsEnabled="{TemplateBinding IsMouseOver}"
                                               Grid.Row="1">
                                            <Track.Thumb>
                                                <Thumb Style="{StaticResource ScrollBarThumbVertical}"
                                                       Margin="2"/>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style TargetType="ListBox">
                        <Style.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Style.Resources>
                    </Style>
                </ListBox.Resources>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Background="{StaticResource checkbox_checked_colour}"
                                  Foreground="{StaticResource text_white}"
                                  IsChecked="{Binding IsChecked}"
                                  Checked="UIe_DestViewChecked"
                                  Unchecked="UIe_DestViewUnchecked">
                            <TextBlock Text="{Binding Name}"/>
                        </CheckBox>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>


            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,5,0,0">
                <Button Click="button_select_all"
                        Content="Select All"
                        Width="80"
                        Height="22"
                        Margin="0,0,5,0"/>
                <Button Click="button_select_none"
                        Content="Select None"
                        Width="80"
                        Height="22"/>
            </StackPanel>

            <StackPanel x:Name="UI_stack_button" HorizontalAlignment="Center">
                <Button Click="button_run"
                        Content="Copy Filters"
                        Margin="0,15,0,0"
                        Width="150"
                        Height="25"/>
            </StackPanel>

        </StackPanel>
        <!--MAIN END-->

        <!--**********************************************************************************************************************************FOOTER START-->
        <Grid   Grid.Row="3"
                Background="{StaticResource header_background}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <TextBlock  Grid.Column="2"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <Hyperlink
                    RequestNavigate="Hyperlink_RequestNavigate"
                    NavigateUri="https://www.patreon.com/EF_tools"
                    FontWeight="Medium"
                    Foreground="{StaticResource button_bg_hover}">
                    Become a Patreon
                </Hyperlink>
            </TextBlock>
        </Grid>
        <!--FOOTER END-->
    </Grid>
</Window>
