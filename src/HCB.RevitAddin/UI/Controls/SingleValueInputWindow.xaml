<Window x:Class="HCB.RevitAddin.UI.Controls.SingleValueInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HCB.RevitAddin.UI.Controls"
        Title="Wprowadzanie wartosci"
        Width="520"
        Height="220"
        MinWidth="420"
        MinHeight="200"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HCB.RevitAddin;component/UI/Styles/SharedStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleTextBlock"
                   Style="{StaticResource SectionTitleStyle}" />

        <TextBlock x:Name="PromptTextBlock"
                   Grid.Row="1"
                   Margin="0,16,0,8"
                   Style="{StaticResource SectionLabelStyle}" />

        <TextBox x:Name="ValueTextBox"
                 Grid.Row="2"
                 VerticalAlignment="Top" />

        <controls:DialogFooterBar x:Name="FooterBar"
                                  Grid.Row="3"
                                  Margin="0,16,0,0"
                                  PrimaryButtonText="Zastosuj"
                                  SecondaryButtonText="Anuluj"
                                  PrimaryButtonClick="ConfirmButton_OnClick"
                                  SecondaryButtonClick="CancelButton_OnClick" />
    </Grid>
</Window>
