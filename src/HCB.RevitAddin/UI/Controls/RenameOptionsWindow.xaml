<Window x:Class="HCB.RevitAddin.UI.Controls.RenameOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HCB.RevitAddin.UI.Controls"
        Title="Opcje zmiany nazw"
        Width="560"
        Height="420"
        MinWidth="480"
        MinHeight="360"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HCB.RevitAddin;component/UI/Styles/SharedStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleTextBlock"
                   Style="{StaticResource SectionTitleStyle}" />

        <GroupBox Grid.Row="1"
                  Header="Parametry zmiany nazw"
                  Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="NumberPrefixLabel"
                           Grid.Row="0"
                           Style="{StaticResource SectionLabelStyle}"
                           Text="Prefiks numeru"
                           VerticalAlignment="Center" />
                <TextBox x:Name="NumberPrefixTextBox"
                         Grid.Row="0"
                         Grid.Column="1" />

                <TextBlock x:Name="NumberFindLabel"
                           Grid.Row="2"
                           Style="{StaticResource SectionLabelStyle}"
                           Text="Szukaj w numerze"
                           VerticalAlignment="Center" />
                <TextBox x:Name="NumberFindTextBox"
                         Grid.Row="2"
                         Grid.Column="1" />

                <TextBlock x:Name="NumberReplaceLabel"
                           Grid.Row="4"
                           Style="{StaticResource SectionLabelStyle}"
                           Text="Zamien w numerze na"
                           VerticalAlignment="Center" />
                <TextBox x:Name="NumberReplaceTextBox"
                         Grid.Row="4"
                         Grid.Column="1" />

                <TextBlock x:Name="NamePrefixLabel"
                           Grid.Row="6"
                           Style="{StaticResource SectionLabelStyle}"
                           Text="Prefiks nazwy"
                           VerticalAlignment="Center" />
                <TextBox x:Name="PrefixTextBox"
                         Grid.Row="6"
                         Grid.Column="1" />

                <TextBlock x:Name="NameFindLabel"
                           Grid.Row="8"
                           Style="{StaticResource SectionLabelStyle}"
                           Text="Szukaj w nazwie"
                           VerticalAlignment="Center" />
                <TextBox x:Name="FindTextBox"
                         Grid.Row="8"
                         Grid.Column="1" />

                <TextBlock x:Name="NameReplaceLabel"
                           Grid.Row="10"
                           Style="{StaticResource SectionLabelStyle}"
                           Text="Zamien w nazwie na"
                           VerticalAlignment="Center" />
                <TextBox x:Name="ReplaceTextBox"
                         Grid.Row="10"
                         Grid.Column="1" />

                <TextBlock x:Name="NameSuffixLabel"
                           Grid.Row="12"
                           Style="{StaticResource SectionLabelStyle}"
                           Text="Sufiks nazwy"
                           VerticalAlignment="Center" />
                <TextBox x:Name="SuffixTextBox"
                         Grid.Row="12"
                         Grid.Column="1" />
            </Grid>
        </GroupBox>

        <controls:DialogFooterBar x:Name="FooterBar"
                                  Grid.Row="2"
                                  Margin="0,16,0,0"
                                  PrimaryButtonText="Zmien nazwy"
                                  SecondaryButtonText="Anuluj"
                                  PrimaryButtonClick="ConfirmButton_OnClick"
                                  SecondaryButtonClick="CancelButton_OnClick" />
    </Grid>
</Window>
