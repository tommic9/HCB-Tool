<Window x:Class="HCB.RevitAddin.UI.Controls.ColorSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HCB.RevitAddin.UI.Controls"
        Title="Wybor kolorow"
        Width="640"
        Height="720"
        MinWidth="520"
        MinHeight="560"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HCB.RevitAddin;component/UI/Styles/SharedStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleTextBlock"
                   Style="{StaticResource SectionTitleStyle}" />

        <TextBox x:Name="SearchTextBox"
                 Grid.Row="1"
                 Margin="0,16,0,8"
                 TextChanged="SearchTextBox_OnTextChanged" />

        <GroupBox Grid.Row="2"
                  x:Name="ItemsGroupBox"
                  Padding="10">
            <DockPanel LastChildFill="True">
                <ComboBox x:Name="FilterGroupComboBox"
                          DockPanel.Dock="Top"
                          Margin="0,0,0,8"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Value"
                          SelectionChanged="FilterGroupComboBox_OnSelectionChanged"
                          Visibility="Collapsed" />
                <controls:SelectionActionsBar DockPanel.Dock="Top"
                                              Margin="0,0,0,8"
                                              LeftButtonText="Wszystkie"
                                              RightButtonText="Brak"
                                              LeftButtonClick="SelectAllButton_OnClick"
                                              RightButtonClick="SelectNoneButton_OnClick" />
                <ListBox x:Name="ItemsListBox"
                         SelectionMode="Extended">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel LastChildFill="True">
                                <Border Width="16"
                                        Height="16"
                                        Margin="0,0,10,0"
                                        CornerRadius="2"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="1"
                                        Background="{Binding PreviewBrush}"
                                        DockPanel.Dock="Left" />
                                <TextBlock VerticalAlignment="Center"
                                           Text="{Binding DisplayName}" />
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </GroupBox>

        <CheckBox x:Name="BlackLinesCheckBox"
                  Grid.Row="3"
                  Margin="0,12,0,0"
                  Content="Nadpisz linie wyswietlania na czarne, grubosc 1" />

        <controls:DialogFooterBar x:Name="FooterBar"
                                  Grid.Row="4"
                                  Margin="0,16,0,0"
                                  PrimaryButtonText="Wybierz"
                                  SecondaryButtonText="Anuluj"
                                  PrimaryButtonClick="ConfirmButton_OnClick"
                                  SecondaryButtonClick="CancelButton_OnClick" />
    </Grid>
</Window>
