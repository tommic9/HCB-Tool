<UserControl x:Class="HCB.RevitAddin.UI.Controls.SelectionActionsBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="32">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HCB.RevitAddin;component/UI/Styles/SharedStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Button Grid.Column="0"
                Style="{StaticResource InlineActionButtonStyle}"
                Content="{Binding LeftButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Click="LeftButton_OnClick" />

        <Button Grid.Column="2"
                Style="{StaticResource InlineActionButtonStyle}"
                Content="{Binding RightButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Click="RightButton_OnClick" />
    </Grid>
</UserControl>
