<Window x:Class="HCB.RevitAddin.Features.StylePreview.UI.StylePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:HCB.RevitAddin.UI.Controls"
        mc:Ignorable="d"
        Title="Style Preview"
        Width="1120"
        Height="760"
        MinWidth="960"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance Type=Window, IsDesignTimeCreatable=False}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HCB.RevitAddin;component/UI/Styles/SharedStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource Brush.TextPrimary}"
                    CornerRadius="10"
                    Padding="18"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="HellCold UI Preview"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="White" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="Designer-friendly preview of SharedStyles.xaml tokens and reusable controls."
                                   Foreground="#DCE8F5" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Top">
                        <Button Content="Primary"
                                Margin="0,0,8,0" />
                        <Button Content="Secondary"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <UniformGrid Grid.Row="1"
                         Columns="3"
                         Margin="0,0,0,16">
                <Border Background="{StaticResource Brush.WindowBackground}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Window Background"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   Text="#FFFFFF" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource Brush.TextPrimary}"
                        BorderBrush="{StaticResource Brush.TextPrimary}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="HellCold Navy"
                                   FontWeight="SemiBold"
                                   Foreground="White" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#DCE8F5"
                                   Text="#2E466F" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource Brush.Accent}"
                        BorderBrush="{StaticResource Brush.Accent}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14">
                    <StackPanel>
                        <TextBlock Text="HellCold Blue"
                                   FontWeight="SemiBold"
                                   Foreground="White" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#E6F5FE"
                                   Text="#1F8ECE" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="2"
                  Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>

                <GroupBox Header="Inputs and Actions"
                          Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   FontSize="18"
                                   Text="Form Elements" />
                        <TextBox Margin="0,12,0,8"
                                 Text="Sample search or input text" />
                        <TextBox Margin="0,0,0,12"
                                 IsEnabled="False"
                                 Text="Disabled input preview" />
                        <controls:SelectionActionsBar Margin="0,0,0,12"
                                                      LeftButtonText="All"
                                                      RightButtonText="None" />
                        <controls:SelectionActionsBar Margin="0,0,0,12"
                                                      LeftButtonText="Select"
                                                      RightButtonText="Reset" />
                        <WrapPanel>
                            <Button Content="Primary Action"
                                    Margin="0,0,8,8" />
                            <Button Content="Secondary Action"
                                    Margin="0,0,8,8"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="Disabled"
                                    Margin="0,0,8,8"
                                    IsEnabled="False" />
                        </WrapPanel>
                        <TextBlock Style="{StaticResource StatusTextStyle}"
                                   Margin="0,4,0,0"
                                   Text="Status text preview based on SharedStyles." />
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Column="1"
                          Header="Lists and Selection">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Margin="0,0,0,10"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   Text="Hover and selected state can be inspected directly in the designer or at runtime." />
                        <ListBox Grid.Row="1"
                                 SelectedIndex="1"
                                 ItemsSource="{Binding ListItems}" />
                    </Grid>
                </GroupBox>
            </Grid>

            <GroupBox Grid.Row="3"
                      Header="Window Composition Example">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="Reference Tool Window" />
                    <Grid Grid.Row="1"
                          Margin="0,14,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <GroupBox Header="Left Section">
                            <DockPanel>
                                <TextBox DockPanel.Dock="Top"
                                         Margin="0,0,0,8"
                                         Text="Search..." />
                                <ListBox SelectedIndex="2"
                                         ItemsSource="{Binding ListItems}" />
                            </DockPanel>
                        </GroupBox>
                        <GroupBox Grid.Column="2"
                                  Header="Right Section">
                            <DockPanel>
                                <controls:SelectionActionsBar DockPanel.Dock="Top"
                                                              Margin="0,0,0,8"
                                                              LeftButtonText="Check"
                                                              RightButtonText="Uncheck" />
                                <ListBox ItemsSource="{Binding ListItems}" />
                            </DockPanel>
                        </GroupBox>
                    </Grid>
                    <DockPanel Grid.Row="2">
                        <TextBlock Style="{StaticResource StatusTextStyle}"
                                   DockPanel.Dock="Left"
                                   Text="This footer mirrors the bottom action/status area used by tool windows." />
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal">
                            <Button Content="Apply"
                                    Width="96"
                                    Margin="0,0,8,0" />
                            <Button Content="Cancel"
                                    Width="96"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </GroupBox>
        </Grid>
    </ScrollViewer>
</Window>
