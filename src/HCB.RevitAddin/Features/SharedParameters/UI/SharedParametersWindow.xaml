<Window x:Class="HCB.RevitAddin.Features.SharedParameters.UI.SharedParametersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HCB.RevitAddin.UI.Controls"
        Title="Shared Parameters"
        Width="640"
        Height="520"
        MinWidth="560"
        MinHeight="440"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HCB.RevitAddin;component/UI/Styles/SharedStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Brakujace parametry wspoldzielone"
                   Style="{StaticResource SectionTitleStyle}" />

        <GroupBox Grid.Row="1"
                  Margin="0,16,0,16"
                  Header="Plik zrodlowy">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Revit pobierze definicje z aktualnie ustawionego pliku Shared Parameters."
                           Style="{StaticResource StatusTextStyle}" />

                <TextBox x:Name="SharedParameterFileTextBox"
                         Grid.Row="2"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalContentAlignment="Top"
                         MinHeight="52" />
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2"
                  Header="Parametry do dodania">
            <DockPanel LastChildFill="True">
                <controls:SelectionActionsBar DockPanel.Dock="Top"
                                              Margin="0,0,0,8"
                                              LeftButtonText="Wszystkie"
                                              RightButtonText="Brak"
                                              LeftButtonClick="SelectAllButton_OnClick"
                                              RightButtonClick="SelectNoneButton_OnClick" />
                <ListBox x:Name="ParametersListBox"
                         SelectionMode="Extended" />
            </DockPanel>
        </GroupBox>

        <controls:DialogFooterBar x:Name="FooterBar"
                                  Grid.Row="3"
                                  Margin="0,16,0,0"
                                  PrimaryButtonText="Dodaj parametry"
                                  SecondaryButtonText="Anuluj"
                                  PrimaryButtonClick="ConfirmButton_OnClick"
                                  SecondaryButtonClick="CancelButton_OnClick" />
    </Grid>
</Window>
